let supported_frame_negative := [
	"#t0052",
	"#t0053",
	"#t0054",
];

let json := new JSON();
let jsonld_parser := new JsonLdParser();
let nq_parser := new NQuadsParser();
let serializer := new JsonLdSerializer(canonical: true);

function _manifest ( path ) {
	return json.load(path);
}

function _option_dict ( raw ) {
	let out := {};
	if ( raw instanceof Dict ) {
		out.set( "use_native_types", raw.get("useNativeTypes") )
			if raw.exists("useNativeTypes");
		out.set( "use_rdf_type", raw.get("useRdfType") )
			if raw.exists("useRdfType");
		out.set( "rdf_direction", raw.get("rdfDirection") )
			if raw.exists("rdfDirection");
		out.set( "spec_version", raw.get("specVersion") )
			if raw.exists("specVersion");
		out.set( "processing_mode", raw.get("processingMode") )
			if raw.exists("processingMode");
		out.set( "content_type", raw.get("contentType") )
			if raw.exists("contentType");
		out.set( "extract_all_scripts", raw.get("extractAllScripts") )
			if raw.exists("extractAllScripts");
		out.set( "base", raw.get("base") )
			if raw.exists("base");
		out.set( "use_jcs", raw.get("useJCS") )
			if raw.exists("useJCS");
	}
	return out;
}

function _input_path ( String input ) {
	return split( input, "#", 2 )[0];
}

let expand_cases := _manifest(expand_manifest);
let expand_count := 0;
let expand_seen := 0;
for ( let c in expand_cases{sequence} ) {
	expand_seen++ if c{"@id"} in supported_expand;
	next unless c{"@id"} in supported_expand;
	expand_count++;
	let input := "" _ c{input};
	let actual := jsonld_expand(
		json.load(root.child(input)),
		{ base: expand_cases{baseIri} _ input },
	);
	let expected := json.load(root.child("" _ c{expect}));
	ok(
		jsonld_object_equals( actual, expected ),
		"W3C JSON-LD Expand " _ c{"@id"},
	);
}
is(
	expand_seen,
	supported_expand.length(),
	"supported W3C Expand cases discovered",
);
ok( expand_count > 0, "W3C Expand cases executed" );

let html_cases := _manifest(html_manifest);
let html_expand_count := 0;
let html_expand_seen := 0;
for ( let c in html_cases{sequence} ) {
	html_expand_seen++ if c{"@id"} in supported_html_expand;
	next unless c{"@id"} in supported_html_expand;
	html_expand_count++;
	let input := "" _ c{input};
	let opts := _option_dict(c{option});
	let base := opts.exists("base") ?
		opts{base} :
		html_cases{baseIri} _ input;
	opts.set( "base", base );
	opts.set( "content_type", "text/html" )
		unless opts.exists("content_type");
	let data := jsonld_decode_text(
		root.child(_input_path(input)).slurp_utf8(),
		base: opts{base},
		content_type: opts{content_type},
		extract_all_scripts: opts.exists("extract_all_scripts") ?
			opts{extract_all_scripts} :
			false,
	);
	let actual := jsonld_expand(data, opts);
	let expected := json.load(root.child("" _ c{expect}));
	ok(
		jsonld_object_equals( actual, expected ),
		"W3C JSON-LD HTML Expand " _ c{"@id"},
	);
}
is(
	html_expand_seen,
	supported_html_expand.length(),
	"supported W3C HTML Expand cases discovered",
);
ok( html_expand_count > 0, "W3C HTML Expand cases executed" );

let compact_cases := _manifest(compact_manifest);
let compact_count := 0;
let compact_seen := 0;
for ( let c in compact_cases{sequence} ) {
	compact_seen++ if c{"@id"} in supported_compact;
	next unless c{"@id"} in supported_compact;
	compact_count++;
	let input := "" _ c{input};
	let actual := jsonld_compact(
		json.load(root.child(input)),
		json.load(root.child("" _ c{context})),
		{ base: compact_cases{baseIri} _ input },
	);
	let expected := json.load(root.child("" _ c{expect}));
	ok(
		jsonld_object_equals( actual, expected ),
		"W3C JSON-LD Compact " _ c{"@id"},
	);
}
is(
	compact_seen,
	supported_compact.length(),
	"supported W3C Compact cases discovered",
);
ok( compact_count > 0, "W3C Compact cases executed" );

let flatten_cases := _manifest(flatten_manifest);
let flatten_count := 0;
let flatten_seen := 0;
for ( let c in flatten_cases{sequence} ) {
	flatten_seen++ if c{"@id"} in supported_flatten;
	next unless c{"@id"} in supported_flatten;
	flatten_count++;
	let input := "" _ c{input};
	let actual := jsonld_flatten(
		json.load(root.child(input)),
		null,
		{ base: flatten_cases{baseIri} _ input },
	);
	let expected := json.load(root.child("" _ c{expect}));
	ok(
		jsonld_object_equals( actual, expected ),
		"W3C JSON-LD Flatten " _ c{"@id"},
	);
}
is(
	flatten_seen,
	supported_flatten.length(),
	"supported W3C Flatten cases discovered",
);
ok( flatten_count > 0, "W3C Flatten cases executed" );

let frame_cases := _manifest(frame_manifest);
let frame_count := 0;
let frame_seen := 0;
let frame_negative_count := 0;
let frame_negative_seen := 0;
for ( let c in frame_cases{sequence} ) {
	frame_seen++ if c{"@id"} in supported_frame;
	next unless c{"@id"} in supported_frame;
	frame_count++;
	let input := "" _ c{input};
	let opts := _option_dict(c{option});
	opts.set( "base", frame_cases{baseIri} _ input );
	let actual := jsonld_frame(
		json.load(root.child(input)),
		json.load(root.child("" _ c{frame})),
		opts,
	);
	let expected := json.load(root.child("" _ c{expect}));
	ok(
		jsonld_object_equals( actual, expected ),
		"W3C JSON-LD Frame " _ c{"@id"},
	);
}
for ( let c in frame_cases{sequence} ) {
	frame_negative_seen++ if c{"@id"} in supported_frame_negative;
	next unless c{"@id"} in supported_frame_negative;
	frame_negative_count++;
	let input := "" _ c{input};
	let opts := _option_dict(c{option});
	opts.set( "base", frame_cases{baseIri} _ input );
	let died := false;
	try {
		jsonld_frame(
			json.load(root.child(input)),
			json.load(root.child("" _ c{frame})),
			opts,
		);
	}
	catch ( Exception e ) {
		died := true;
	}
	ok(
		died,
		"W3C JSON-LD Frame negative " _ c{"@id"},
	);
}
is(
	frame_seen,
	supported_frame.length(),
	"supported W3C Frame cases discovered",
);
is(
	frame_negative_seen,
	supported_frame_negative.length(),
	"supported W3C negative Frame cases discovered",
);
ok( frame_count > 0, "W3C Frame cases executed" );
ok( frame_negative_count > 0, "W3C negative Frame cases executed" );

let to_manifest := _manifest(to_rdf_manifest);
let to_count := 0;
let to_seen := 0;
for ( let c in to_manifest{sequence} ) {
	to_seen++ if c{"@id"} in supported_to_rdf;
	next unless c{"@id"} in supported_to_rdf;
	to_count++;
	let input := "" _ c{input};
	let to_opts := _option_dict(c{option});
	let use_jcs := to_opts.exists("use_jcs") ? to_opts{use_jcs} : false;
	let actual := jsonld_parser.parse_file(
		root.child(input),
		base: to_manifest{baseIri} _ input,
		use_jcs: use_jcs,
	);
	let expected := nq_parser.parse_file(root.child("" _ c{expect}));
	ok(
		rdf_datasets_isomorphic( actual, expected ),
		"W3C JSON-LD ToRDF " _ c{"@id"},
	);
}
is( to_seen, supported_to_rdf.length(), "supported W3C ToRDF cases discovered" );
ok( to_count > 0, "W3C ToRDF cases executed" );

let from_manifest := _manifest(from_rdf_manifest);
let from_count := 0;
let from_seen := 0;
for ( let c in from_manifest{sequence} ) {
	from_seen++ if c{"@id"} in supported_from_rdf;
	next unless c{"@id"} in supported_from_rdf;
	from_count++;
	let quads := nq_parser.parse_file(root.child("" _ c{input}));
	let actual := json.decode(serializer.serialize(quads));
	let expected := json.load(root.child("" _ c{expect}));
	ok(
		jsonld_object_equals( actual, expected ),
		"W3C JSON-LD FromRDF " _ c{"@id"},
	);
}
is(
	from_seen,
	supported_from_rdf.length(),
	"supported W3C FromRDF cases discovered",
);
ok( from_count > 0, "W3C FromRDF cases executed" );

done_testing();
