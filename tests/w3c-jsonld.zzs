from test/more import *;

author_testing();
requires_capability( "fs" );

from rdf import NQuadsParser, rdf_datasets_isomorphic;
from rdf/parser/jsonld import JsonLdParser;
from rdf/serializer/jsonld import JsonLdSerializer;
from rdf/jsonld import
	jsonld_compact,
	jsonld_decode_text,
	jsonld_expand,
	jsonld_flatten,
	jsonld_frame,
	jsonld_object_equals;
from std/data/json import JSON;
from std/io import Path;
from std/string import split;

let root := new Path("tests/w3c/json-ld-api");
let to_rdf_manifest := root.child("toRdf-manifest.jsonld");
let from_rdf_manifest := root.child("fromRdf-manifest.jsonld");
let expand_manifest := root.child("expand-manifest.jsonld");
let compact_manifest := root.child("compact-manifest.jsonld");
let flatten_manifest := root.child("flatten-manifest.jsonld");
let html_manifest := root.child("html-manifest.jsonld");
let frame_manifest := root.child("frame-manifest.jsonld");

if ( not to_rdf_manifest.exists() or not from_rdf_manifest.exists() or
	not expand_manifest.exists() or not compact_manifest.exists() or
	not flatten_manifest.exists() or not html_manifest.exists() or
	not frame_manifest.exists() ) {
	pass("W3C JSON-LD manifests not vendored");
	done_testing();
}

