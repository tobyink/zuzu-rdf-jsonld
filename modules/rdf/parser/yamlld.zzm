=encoding utf8

=head1 NAME

rdf/parser/yamlld - YAML-LD parser.

=cut

from rdf/parser import RdfParser;
from rdf/jsonld/core import jsonld_to_rdf;
from std/data/yaml import YAML;

class YamlLdParser with RdfParser {
	method parse_string ( String text, ... PairList options ) {
		return jsonld_to_rdf( ( new YAML() ).decode(text), ...options );
	}
}
